<div class="footer-inner">
    <div class="footer-brand">
        <a href="https://rainven.com/" class="site-logo" aria-label="{{@site.title}}">
            {{#if @site.logo}}
                <img src="{{@site.logo}}" alt="{{@site.title}}">
            {{else}}
                <span>{{@site.title}}</span>
            {{/if}}
        </a>
    </div>

    <nav class="footer-navigation" aria-label="Secondary navigation">
        {{navigation type="secondary"}}
    </nav>

    <nav class="footer-socials" aria-label="Social links">
        {{#if @site.twitter}}
            <a class="footer-social-link social-link-x" href="{{social_url type="twitter"}}" target="_blank" rel="noopener noreferrer" aria-label="X">
                {{> "icons/brand" icon="x"}}
            </a>
        {{/if}}

        {{#if @site.youtube}}
            <a class="footer-social-link social-link-youtube" href="{{social_url type="youtube"}}" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
                {{> "icons/brand" icon="youtube"}}
            </a>
        {{/if}}

        {{#if @site.tiktok}}
            <a class="footer-social-link social-link-tiktok" href="{{social_url type="tiktok"}}" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
                {{> "icons/brand" icon="tiktok"}}
            </a>
        {{/if}}

        {{#if @site.linkedin}}
            <a class="footer-social-link social-link-linkedin" href="{{social_url type="linkedin"}}" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
                {{> "icons/brand" icon="linkedin"}}
            </a>
        {{/if}}

        {{#if @custom.show_github_social_link}}
            {{#if @custom.github_url}}
                <a class="footer-social-link social-link-github" href="{{@custom.github_url}}" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
                    {{> "icons/brand" icon="github"}}
                </a>
            {{/if}}
        {{/if}}
    </nav>

    {{#unless @custom.hide_footer_theme_toggle}}
        <button class="footer-theme-toggle" type="button" data-theme-toggle aria-label="Toggle color theme">
            <span class="footer-theme-option footer-theme-option-dark">
                <span class="footer-theme-icon" aria-hidden="true">
                    <svg width="18" height="18" fill="currentColor" viewBox="0 0 256 256">
                        <path d="M235.54,150.21a104.84,104.84,0,0,1-37,52.91A104,104,0,0,1,32,120,103.09,103.09,0,0,1,52.88,57.48a104.84,104.84,0,0,1,52.91-37,8,8,0,0,1,10,10,88.08,88.08,0,0,0,109.8,109.8,8,8,0,0,1,10,10Z"></path>
                    </svg>
                </span>
                <span>Dark</span>
            </span>
            <span class="footer-theme-option footer-theme-option-light">
                <span class="footer-theme-icon" aria-hidden="true">
                    <svg width="18" height="18" fill="currentColor" viewBox="0 0 256 256">
                        <path d="M120,40V16a8,8,0,0,1,16,0V40a8,8,0,0,1-16,0Zm72,88a64,64,0,1,1-64-64A64.07,64.07,0,0,1,192,128Zm-16,0a48,48,0,1,0-48,48A48.05,48.05,0,0,0,176,128ZM58.34,69.66A8,8,0,0,0,69.66,58.34l-16-16A8,8,0,0,0,42.34,53.66Zm0,116.68-16,16a8,8,0,0,0,11.32,11.32l16-16a8,8,0,0,0-11.32-11.32ZM192,72a8,8,0,0,0,5.66-2.34l16-16a8,8,0,0,0-11.32-11.32l-16,16A8,8,0,0,0,192,72Zm5.66,114.34a8,8,0,0,0-11.32,11.32l16,16a8,8,0,0,0,11.32-11.32ZM48,128a8,8,0,0,0-8-8H16a8,8,0,0,0,0,16H40A8,8,0,0,0,48,128Zm80,80a8,8,0,0,0-8,8v24a8,8,0,0,0,16,0V216A8,8,0,0,0,128,208Zm112-88H216a8,8,0,0,0,0,16h24a8,8,0,0,0,0-16Z"></path>
                    </svg>
                </span>
                <span>Light</span>
            </span>
        </button>
    {{/unless}}

    <p class="footer-copyright">
        &copy; {{date format="YYYY"}} {{@site.title}}
    </p>
</div>
