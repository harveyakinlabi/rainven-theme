<section class="post-share" aria-labelledby="post-share-title">
    <h3 id="post-share-title">Share</h3>
    <div class="post-share-buttons">
        <a
            class="post-share-button post-share-button-x social-link-x"
            href="https://x.com/intent/tweet?text={{encode title}}&amp;url={{url absolute="true"}}"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Share on X"
        >
            {{> "icons/brand" icon="x"}}
        </a>
        <a
            class="post-share-button post-share-button-facebook social-link-facebook"
            href="https://www.facebook.com/sharer.php?u={{url absolute="true"}}"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Share on Facebook"
        >
            {{> "icons/brand" icon="facebook"}}
        </a>
        <a
            class="post-share-button post-share-button-threads social-link-threads"
            href="https://www.threads.net/intent/post?text={{encode title}}%20{{url absolute="true"}}"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Share on Threads"
        >
            {{> "icons/brand" icon="threads"}}
        </a>
        <a
            class="post-share-button post-share-button-native"
            href="#/share"
            aria-label="Share this post"
        >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M13 4v4C6.43 9.03 3.98 14.79 3 20c-.04.21 5.38-5.96 10-6v4l8-7-8-7Z"></path>
            </svg>
        </a>
    </div>
</section>
