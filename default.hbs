<!DOCTYPE html>
<html lang="{{@site.locale}}">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{meta_title}}</title>
    {{#if @site.icon}}
        <link rel="icon" href="{{@site.icon}}" type="image/png">
        <link rel="apple-touch-icon" href="{{@site.icon}}">
    {{/if}}
    <script>
        (function () {
            var mediaQuery = window.matchMedia('(prefers-color-scheme: dark)');

            function applyTheme() {
                var storedTheme = localStorage.getItem('theme');
                var useDark = storedTheme === 'dark' || (!storedTheme && mediaQuery.matches);

                if (useDark) {
                    document.documentElement.setAttribute('data-theme', 'dark');
                } else {
                    document.documentElement.removeAttribute('data-theme');
                }
            }

            applyTheme();
            mediaQuery.addEventListener('change', applyTheme);
        })();
    </script>
    {{ghost_head}}
    <link rel="stylesheet" href="{{asset "css/main.css"}}">
    <style>
        :root {
            {{#if @custom.theme_accent_color}}
                --rainven-accent-color: {{@custom.theme_accent_color}};
            {{/if}}
            --ghost-accent-color: var(--rainven-accent-color);
        }
    </style>
</head>
<body class="{{body_class}}{{#if @custom.style_last_nav_item_as_cta}} has-nav-cta{{/if}}">
    <div class="site-wrapper">
        <header class="site-header" data-site-header>
            <nav class="site-nav" aria-label="Main navigation">
                <div class="site-nav-left">
                    <a href="{{@site.url}}" class="site-logo" aria-label="{{@site.title}}">
                        {{#if @site.logo}}
                            <img src="{{@site.logo}}" alt="{{@site.title}}">
                        {{else}}
                            <span>{{@site.title}}</span>
                        {{/if}}
                    </a>
                </div>

                <div class="site-nav-right">
                    <div class="site-nav-menu">
                        {{navigation}}
                    </div>

                    <div class="nav-tools">
                        {{#unless @custom.hide_header_theme_toggle}}
                            <button class="theme-toggle" data-theme-toggle aria-label="Toggle color theme">
                                <span class="theme-icon-light" aria-hidden="true">
                                    <svg width="18" height="18" fill="currentColor" viewBox="0 0 256 256">
                                        <path d="M235.54,150.21a104.84,104.84,0,0,1-37,52.91A104,104,0,0,1,32,120,103.09,103.09,0,0,1,52.88,57.48a104.84,104.84,0,0,1,52.91-37,8,8,0,0,1,10,10,88.08,88.08,0,0,0,109.8,109.8,8,8,0,0,1,10,10Z"></path>
                                    </svg>
                                </span>
                                <span class="theme-icon-dark" aria-hidden="true">
                                    <svg width="18" height="18" fill="currentColor" viewBox="0 0 256 256">
                                        <path d="M120,40V16a8,8,0,0,1,16,0V40a8,8,0,0,1-16,0Zm72,88a64,64,0,1,1-64-64A64.07,64.07,0,0,1,192,128Zm-16,0a48,48,0,1,0-48,48A48.05,48.05,0,0,0,176,128ZM58.34,69.66A8,8,0,0,0,69.66,58.34l-16-16A8,8,0,0,0,42.34,53.66Zm0,116.68-16,16a8,8,0,0,0,11.32,11.32l16-16a8,8,0,0,0-11.32-11.32ZM192,72a8,8,0,0,0,5.66-2.34l16-16a8,8,0,0,0-11.32-11.32l-16,16A8,8,0,0,0,192,72Zm5.66,114.34a8,8,0,0,0-11.32,11.32l16,16a8,8,0,0,0,11.32-11.32ZM48,128a8,8,0,0,0-8-8H16a8,8,0,0,0,0,16H40A8,8,0,0,0,48,128Zm80,80a8,8,0,0,0-8,8v24a8,8,0,0,0,16,0V216A8,8,0,0,0,128,208Zm112-88H216a8,8,0,0,0,0,16h24a8,8,0,0,0,0-16Z"></path>
                                    </svg>
                                </span>
                            </button>
                        {{/unless}}
                    </div>

                    <button class="menu-toggle" data-menu-toggle aria-label="Open menu" aria-controls="mobile-menu" aria-expanded="false">
                        <span aria-hidden="true"></span>
                        <span aria-hidden="true"></span>
                        <span aria-hidden="true"></span>
                    </button>
                </div>
            </nav>

            <div class="mobile-menu" id="mobile-menu" data-mobile-menu hidden>
                <nav class="mobile-menu-inner" aria-label="Mobile navigation">
                    {{navigation}}
                </nav>
            </div>
        </header>

        <main id="site-main" class="site-main">
            {{{body}}}
        </main>

        <footer class="site-footer">
            {{> footer}}
        </footer>
    </div>

    {{ghost_foot}}
    <script src="{{asset "js/main.js"}}" defer></script>
</body>
</html>
