{{!< default}}

<section class="site-hero" aria-labelledby="site-hero-title">
    <div class="site-hero-avatar">
        {{#if profile_image}}
            <div class="progressive-image">
                <img
                    class="progressive-image-img"
                    src="{{img_url profile_image size="xxs"}}"
                    data-progressive-src="{{img_url profile_image size="m"}}"
                    alt="{{name}}"
                    loading="eager"
                    decoding="async"
                >
                <span class="progressive-image-blur" aria-hidden="true"></span>
            </div>
        {{else}}
            <span
                data-author-initials
                data-author-name="{{name}}"
                aria-hidden="true"
            ></span>
        {{/if}}
    </div>

    <h1 id="site-hero-title">{{name}}</h1>

    {{#if bio}}
        <p class="site-hero-description">{{bio}}</p>
    {{/if}}

    {{#if twitter}}
        <nav class="site-hero-socials" aria-label="Social links">
            <a class="site-hero-social-link social-link-x" href="https://x.com/{{twitter}}" target="_blank" rel="noopener noreferrer" aria-label="X">
                {{> "icons/brand" icon="x"}}
            </a>
            {{#if facebook}}
                <a class="site-hero-social-link social-link-facebook" href="https://www.facebook.com/{{facebook}}" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
                    {{> "icons/brand" icon="facebook"}}
                </a>
            {{/if}}
        </nav>
    {{else}}
        {{#if facebook}}
            <nav class="site-hero-socials" aria-label="Social links">
                <a class="site-hero-social-link social-link-facebook" href="https://www.facebook.com/{{facebook}}" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
                    {{> "icons/brand" icon="facebook"}}
                </a>
            </nav>
        {{/if}}
    {{/if}}
</section>

{{> "post-feed"
    feed_class="latest-posts"
    feed_id="latest"
    labelledby="latest-posts-title"
    heading="Latest Posts"
    list_class="latest-post-list related-post-list"
    card_variant="related"
}}
