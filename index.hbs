{{!< default}}

<section class="site-hero" aria-labelledby="site-hero-title">
    {{#get "authors" limit="1" include="count.posts" order="count.posts desc" as |hero_authors|}}
        {{#foreach hero_authors}}
            <div class="site-hero-avatar">
                {{#if profile_image}}
                    <div class="progressive-image">
                        <img
                            class="progressive-image-img"
                            src="{{img_url profile_image size="xxs"}}"
                            data-progressive-src="{{img_url profile_image size="m"}}"
                            alt="{{name}}"
                            loading="eager"
                            decoding="async"
                        >
                        <span class="progressive-image-blur" aria-hidden="true"></span>
                    </div>
                {{else}}
                    <span
                        data-author-initials
                        data-author-name="{{name}}"
                        aria-hidden="true"
                    ></span>
                {{/if}}
            </div>

            <h1 id="site-hero-title">{{name}}</h1>

            {{#if bio}}
                <p class="site-hero-description">{{bio}}</p>
            {{else}}
                {{#if @site.description}}
                    <p class="site-hero-description">{{@site.description}}</p>
                {{/if}}
            {{/if}}
        {{/foreach}}
    {{else}}
        <div class="site-hero-avatar">
            <span
                data-author-initials
                data-author-name="{{@site.title}}"
                aria-hidden="true"
            ></span>
        </div>

        <h1 id="site-hero-title">{{@site.title}}</h1>

        {{#if @site.description}}
            <p class="site-hero-description">{{@site.description}}</p>
        {{/if}}
    {{/get}}

    <nav class="site-hero-socials" aria-label="Social links">
        {{#if @site.twitter}}
            <a class="site-hero-social-link social-link-x" href="{{social_url type="twitter"}}" target="_blank" rel="noopener noreferrer" aria-label="X">
                {{> "icons/brand" icon="x"}}
            </a>
        {{/if}}

        {{#if @site.youtube}}
            <a class="site-hero-social-link social-link-youtube" href="{{social_url type="youtube"}}" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
                {{> "icons/brand" icon="youtube"}}
            </a>
        {{/if}}

        {{#if @site.tiktok}}
            <a class="site-hero-social-link social-link-tiktok" href="{{social_url type="tiktok"}}" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
                {{> "icons/brand" icon="tiktok"}}
            </a>
        {{/if}}

        {{#if @site.linkedin}}
            <a class="site-hero-social-link social-link-linkedin" href="{{social_url type="linkedin"}}" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
                {{> "icons/brand" icon="linkedin"}}
            </a>
        {{/if}}

        {{#if @custom.show_github_social_link}}
            {{#if @custom.github_url}}
                <a class="site-hero-social-link social-link-github" href="{{@custom.github_url}}" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
                    {{> "icons/brand" icon="github"}}
                </a>
            {{/if}}
        {{/if}}
    </nav>
</section>

{{> "post-feed"
    feed_class="latest-posts"
    feed_id="latest"
    labelledby="latest-posts-title"
    heading="Latest Posts"
    list_class="latest-post-list related-post-list"
    card_variant="related"
}}
